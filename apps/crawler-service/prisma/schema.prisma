generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model StockPrice {
  id        Int      @id @default(autoincrement())
  symbol    String
  time      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    BigInt
  createdAt DateTime @default(now())

  @@unique([symbol, time])
}

model AiAnalysis {
  id        Int      @id @default(autoincrement())
  symbol    String
  content   String   @db.Text
  createdAt DateTime @default(now())
}